# Génerer les tickets automatiquement
def generator_tickets( ) :
	nombre_min = 5
	nombre_max = 8
	all_chars = string.digits + string.ascii_letters + string.punctuation
	ticket = " ".join(choice(all_chars) for x in range(randint(nombre_min, nombre_max)))
	return ticket


# OBTENIR UNE PLACE

def obtenir_place():

    nom = input("\nEntrez votre nom : ")

    try:
        age = int(input("Quel est votre âge : "))
        if age > 130:
        	print("\nÂge trop grand !")
        	obtenir_place()
        	return
        elif age <= 5:
        	print("\nÂge très petit ! Entrer gratuit.")
        	menu_principal()
        	return

    except:
        print("\nVeuillez entrer un âge valide.")
        obtenir_place()
        return
        
    choix = input("Souhaitez-vous du PipCon ? oui/non : ").lower()
    	
    if age < 18 and choix == "oui":
    	montant = 12
    elif age < 18 and choix == "non":
    	montant = 7
    elif age >= 18 and choix == "oui":
    	montant = 15
    elif age >= 18 and choix == "non":
    	montant = 10

    else:
    	print("\nVous devez repondre soit oui / soit non !")
    	obtenir_place()
    	return

    date = datetime.now().strftime("%d/%m/%Y | %H:%M")

    with open(FICHIER, "a", newline="", encoding="utf-8") as fichier:

        writer = csv.writer(fichier)

        writer.writerow([nom, age, montant, date])

    print(f"\nPlace réservée avec succès !\nVoici votre ticket:  {generator_tickets()} ")
    print(f"Montant a payé {montant}$")

    retour_menu()


